<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="App_Registro_Ponto.Views.RegistroPage">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label 
            Text="Registro de Ponto"
            FontSize="26"
            HorizontalOptions="Center"
            FontAttributes="Bold"/>

        <Button
            Text="Registrar Ponto"
            Clicked="OnRegistrarPonto"/>

        <Label
            x:Name="lblLocalizacao"
            Text="Localização aparecerá aqui"/>

        <Label
            x:Name="lblHorario"
            Text="Horário aparecerá aqui"/>

    </VerticalStackLayout>

</ContentPage>