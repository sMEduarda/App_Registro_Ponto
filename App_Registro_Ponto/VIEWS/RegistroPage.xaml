<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="App_Registro_Ponto.RegistroPage">

    <VerticalStackLayout Padding="30" Spacing="15">

        <Label
            Text="Registro de Ponto"
            FontSize="28"
            HorizontalOptions="Center"/>

        <Button
            Text="Registrar Entrada"
            Clicked="OnRegistrarEntrada"/>

        <Button
            Text="Registrar Saída"
            Clicked="OnRegistrarSaida"/>

        <Label x:Name="lblEntradaHora"/>
        <Label x:Name="lblEntradaLat"/>
        <Label x:Name="lblEntradaLong"/>

        <Label x:Name="lblSaidaHora"/>
        <Label x:Name="lblSaidaLat"/>
        <Label x:Name="lblSaidaLong"/>

    </VerticalStackLayout>

</ContentPage>
